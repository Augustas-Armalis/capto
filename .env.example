# ─── Site ──────────────────────────────────────────────────────────────
# Local: http://localhost:3000  ·  Production: https://capto.video
NEXT_PUBLIC_SITE_URL=https://capto.video
NEXT_PUBLIC_SITE_NAME=Capto

# ─── Auth (better-auth) ────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-me            # openssl rand -base64 32
BETTER_AUTH_URL=https://capto.video

# ─── Database (Neon Postgres, Frankfurt) ───────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── Encryption (AES-256-GCM for stored user API keys) ─────────────────
ENCRYPTION_KEY=replace-me                # openssl rand -hex 32

# ─── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx          # from the webhook endpoint you create after deploy

# One price ID per plan × interval × currency (8 total).
# Capto Pro €6.99/$7.99 mo · €59.88/$71.88 yr · Ultra €17.99/$19.99 mo · €179.90/$203.88 yr
STRIPE_PRICE_PRO_MONTHLY_EUR=price_xxx
STRIPE_PRICE_PRO_MONTHLY_USD=price_xxx
STRIPE_PRICE_PRO_ANNUAL_EUR=price_xxx
STRIPE_PRICE_PRO_ANNUAL_USD=price_xxx
STRIPE_PRICE_ULTRA_MONTHLY_EUR=price_xxx
STRIPE_PRICE_ULTRA_MONTHLY_USD=price_xxx
STRIPE_PRICE_ULTRA_ANNUAL_EUR=price_xxx
STRIPE_PRICE_ULTRA_ANNUAL_USD=price_xxx

# ─── Optional house Groq fallback (reserved, not consumed yet) ─────────
GROQ_API_KEY=
