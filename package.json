{
  "name": "capto-web",
  "version": "0.1.0",
  "private": true,
  "description": "Capto — AI captions for short-form video. SaaS web platform.",
  "scripts": {
    "dev": "next dev --turbo",
    "gen:carousel": "node scripts/gen-carousel.mjs",
    "prebuild": "node scripts/gen-carousel.mjs",
    "predev": "node scripts/gen-carousel.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "cf:build": "node scripts/gen-carousel.mjs && opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "node scripts/gen-carousel.mjs && opennextjs-cloudflare build && wrangler deploy"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "better-auth": "^1.1.7",
    "drizzle-orm": "^0.45.2",
    "lenis": "^1.3.23",
    "lucide-react": "^0.469.0",
    "motion": "^11.15.0",
    "next": "^16.2.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.31.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.102.0"
  }
}
